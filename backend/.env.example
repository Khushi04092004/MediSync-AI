# Copy this file, rename the copy to ".env" (remove ".example"), and fill in what you need.
# Only GEMINI_API_KEY is commonly used - everything else is optional.

# --- Gemini AI (recommended) ---
# Get a free key at https://aistudio.google.com/app/apikey
# Without this, the app runs in DEMO MODE with sample AI responses - fully usable for testing.
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Admin signup code (optional) ---
# Set this to any secret string of your choice. On the Sign Up page, anyone who
# enters this exact code gets an "admin" account (can add/edit/delete medicines
# in Inventory). Leave blank and NOBODY can create an admin account via signup -
# every signup will be a regular "customer" account.
ADMIN_SIGNUP_CODE=

# --- Razorpay real payment gateway (optional, UNVERIFIED without real keys) ---
# Only needed if you want real UPI/Card payments instead of the simulated ones.
# Get test keys at https://dashboard.razorpay.com/app/keys
# See payment_gateway.py and the README's "Real Payment Gateway" section.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Shiprocket real courier integration (optional, UNVERIFIED without a real account) ---
# Only needed if you want real courier booking instead of the simulated tracking.
# See delivery_provider.py and the README's "Real Courier Integration" section.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
